# Copy to .env.local for local development (never commit .env.local)

# Supabase — browser-safe
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Session secret — server-only (never use NEXT_PUBLIC_ prefix)
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars
